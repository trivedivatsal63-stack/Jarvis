# Get your Groq API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Get your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Get your OpenWeatherMap API key from https://openweathermap.org/api (free)
WEATHER_API_KEY=your_weather_api_key

# Get your NewsAPI key from https://newsapi.org (free)
NEWS_API_KEY=your_news_api_key

# Telegram bot token from @BotFather (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=

# Redis URL (optional - leave empty to disable caching)
REDIS_URL=
